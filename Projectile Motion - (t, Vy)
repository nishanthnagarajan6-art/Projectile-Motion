   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import pandas as pd \n",
    "\n",
    "M = int(input(\"Enter Weight Of Object: \"))\n",
    "g = 9.81\n",
    "V = int(input(\"Enter Intial Velocity: \"))\n",
    "ang = int(input(\"Enter Angle Respective To X-Axis: \"))\n",
    "K = float(input(\"Enter Coefficient Of Drag: \"))\n",
    "y = [float(input(\"Intial Height: \"))]\n",
    "x = [0]\n",
    "\n",
    "Vx = [V * np.cos(ang * np.pi / 180)]\n",
    "Vy = [V * np.sin(ang * np.pi / 180)]\n",
    "kenergy = [1 / 2 * M * V**2]\n",
    "penergy = [M * g * y[0]]\n",
    "total_energy = [1 / 2 * M * V**2 + M * g * y[0]]\n",
    "\n",
    "Vel = np.sqrt(Vx[0]**2 + Vy[0]**2)\n",
    "F = K * Vel**2\n",
    "aX = [-(K * Vel * Vx[0] / M)]\n",
    "aY = [-g - (K * Vel * Vy[0] / M)]\n",
    "\n",
    "t = [0]\n",
    "counter = 0 \n",
    "dt = float(input(\"Enter Intervals Of Time: \"))\n",
    "           \n",
    "while y[-1] >= 0 and penergy[-1] >= 0:\n",
    "    t.append(t[counter] + dt)\n",
    "    Vx.append(Vx[counter] + aX[counter] * dt)\n",
    "    Vy.append(Vy[counter] + aY[counter] * dt)\n",
    "    \n",
    "    x.append(x[counter] + Vx[counter] * dt)\n",
    "    y.append(y[counter] + Vy[counter] * dt)\n",
    "    \n",
    "    Vel = np.sqrt(Vx[counter + 1]**2 + Vy[counter + 1]**2)\n",
    "    F = K * Vel**2\n",
    "    aX.append(-(K * Vel * Vx[counter + 1] / M))\n",
    "    aY.append(-g - (K * Vel * Vy[counter + 1] / M))\n",
    "    \n",
    "    kenergy.append(1 / 2 * M * Vel**2)\n",
    "    penergy.append(M * g * y[counter + 1])\n",
    "    total_energy.append(kenergy[counter + 1] + penergy[counter + 1])\n",
    "\n",
    "    \n",
    "    counter += 1 \n",
    "           \n",
    "\n",
    "data = pd.DataFrame({\n",
    "    \"time\": t,\n",
    "    \"x_position\": x,\n",
    "    \"y_position\": y,\n",
    "    \"x_velocity\": Vx,\n",
    "    \"y_velocity\": Vy,\n",
    "    \"x_acceleration\": aX,\n",
    "    \"y_acceleration\": aY,\n",
    "    \"kinetic_energy\": kenergy,\n",
    "    \"potential_energy\": penergy,\n",
    "    \"total_energy\": total_energy\n",
    "})\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "\n",
    "axes[0, 0].plot(data[\"x_position\"], data[\"y_position\"], color=\"royalblue\")\n",
    "axes[0, 0].set_title(\"X vs Y\")\n",
    "axes[0, 0].set_xlabel(\"X Position\")\n",
    "axes[0, 0].set_ylabel(\"Y Position\")\n",
    "\n",
    "axes[0, 1].plot(data[\"time\"], data[\"x_acceleration\"], color=\"darkorange\")\n",
    "axes[0, 1].set_title(\"Time vs X Acceleration\")\n",
    "axes[0, 1].set_xlabel(\"Time\")\n",
    "axes[0, 1].set_ylabel(\"X Acceleration\")\n",
    "\n",
    "axes[1, 0].plot(data[\"time\"], data[\"total_energy\"], label=\"Total\", color=\"black\", linewidth=2)\n",
    "axes[1, 0].plot(data[\"time\"], data[\"kinetic_energy\"], label=\"Kinetic\", color=\"purple\")\n",
    "axes[1, 0].plot(data[\"time\"], data[\"potential_energy\"], label=\"Potential\", color=\"goldenrod\")\n",
    "axes[1, 0].set_title(\"Time vs Energy\")\n",
    "axes[1, 0].set_xlabel(\"Time\")\n",
    "axes[1, 0].set_ylabel(\"Energy\")\n",
    "axes[1, 0].legend()\n",
    "\n",
    "axes[1, 1].plot(data[\"time\"], data[\"x_velocity\"], label=\"Vx\", color=\"seagreen\")\n",
    "axes[1, 1].plot(data[\"time\"], data[\"y_velocity\"], label=\"Vy\", color=\"crimson\")\n",
    "axes[1, 1].set_title(\"Time vs Velocity Components\")\n",
    "axes[1, 1].set_xlabel(\"Time\")\n",
    "axes[1, 1].set_ylabel(\"Velocity\")\n",
    "axes[1, 1].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "table_1s = data.iloc[::int(round(1 / dt)) if dt < 1 else 1].copy()\n",
    "print(table_1s)\n",
    "\n",
    "data.to_csv(\"projectile_simulation_results.csv\", index=False)\n",
    "table_1s.to_csv(\"projectile_table_1s.csv\", index=False)\n"
   ]
